# Auto-Agent secrets — copy to `.env.local` (gitignored — never commit). `.env` format,
# one KEY=value per line, no quotes.

# Claude Code headless auth (REQUIRED for 24/7). A launchd/systemd/cloud process can't use
# your interactive login. Get a long-lived token: `claude setup-token`, paste it here.
CLAUDE_CODE_OAUTH_TOKEN=

# Linear access for the headless loop (REQUIRED). Linear → Settings → Security & access →
# Personal API keys → New API key.
LINEAR_API_KEY=

# Optional: a GitHub token for `gh` if the environment isn't already authenticated
# (e.g. cloud routines / servers). Needs repo scope (open PRs, merge).
# GH_TOKEN=
